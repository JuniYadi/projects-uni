{
  "name": "@univpn/desktop",
  "private": true,
  "version": "1.0.0",
  "main": "main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0",
    "axios": "^1.7.0",
    "zod": "^3.23.0",
    "electron-store": "^10.0.0",
    "@univpn/shared": "*"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "~5.3.0",
    "jest": "^29.0.0",
    "@types/react": "^19.0.0"
  },
  "build": {
    "appId": "com.univpn.desktop",
    "productName": "UniVPN",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
